{
  "name": "vllm-triton-mtp-w4a16",
  "description": "vLLM V1 Google official W4A16 (gemma-4-E4B-it-qat-w4a16-ct, compressed-tensors) served as gemma-4-e4b-it + TRITON_ATTN + MTP spec-decode (K=7). The competitive build: quant + spec-decode.",
  "dependencies": [
    "vllm==0.22.1",
    "transformers==5.9.0"
  ],
  "model_id": "google/gemma-4-E4B-it",
  "served_model_name": "gemma-4-e4b-it",
  "port": 8000,
  "serve": [
    "python",
    "serve.py"
  ],
  "env": {
    "MAX_MODEL_LEN": "4096",
    "GPU_MEMORY_UTILIZATION": "0.90",
    "MAX_NUM_BATCHED_TOKENS": "512",
    "MAX_NUM_SEQS": "1",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
    "ATTENTION_BACKEND": "TRITON_ATTN",
    "ENABLE_PREFIX_CACHING": "1",
    "SPECULATIVE_CONFIG": "{\"method\": \"mtp\", \"model\": \"google/gemma-4-E4B-it-assistant\", \"num_speculative_tokens\": 7}",
    "SERVE_MODEL_OVERRIDE": "google/gemma-4-E4B-it-qat-w4a16-ct"
  }
}